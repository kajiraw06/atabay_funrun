{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "routes": [
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/success", "dest": "/success.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
